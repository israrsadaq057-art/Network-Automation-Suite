!
! ============================================
! Device: {{ device.name }}
! Generated by ZTP - Network Automation Suite
! Network Engineer: Israr Sadaq
! Date: {{ now() if now is defined else 'Auto-generated' }}
! ============================================
!
hostname {{ device.name }}
!
! Domain and DNS
ip domain-name resourceacademia.local
ip name-server 10.10.10.10
ip name-server 8.8.8.8
!
! Usernames
username admin privilege 15 secret {{ device.password }}
username support privilege 5 secret support123
!
! Enable password
enable secret {{ device.enable_password }}
!
! Console and VTY
line con 0
 exec-timeout 0 0
 logging synchronous
!
line vty 0 4
 transport input ssh
 login local
 exec-timeout 15 0
!
! SSH configuration
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
!
! Management Interface
interface Vlan1
 ip address {{ device.mgmt_ip }} 255.255.0.0
 no shutdown
!
! Enable IP routing
ip routing
!
! SNMP configuration for monitoring
snmp-server community public RO
snmp-server location {{ device.name }}
snmp-server contact admin@resourceacademia.local
snmp-server host 10.10.10.40 version 2c public
!
! NTP configuration
ntp server 10.10.10.10
ntp update-calendar
!
! Logging
logging buffered 4096
logging console notifications
logging monitor notifications
!
! End of base configuration
!